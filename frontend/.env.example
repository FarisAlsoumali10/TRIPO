# ── AI ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth ──────────────────────────
# Same Client ID as backend — from https://console.cloud.google.com/
# Under Authorized JavaScript origins add: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── Facebook OAuth ────────────────────────
# From https://developers.facebook.com/ → Your App → Settings → Basic → App ID
# Under Valid OAuth Redirect URIs add: http://localhost:5173
FACEBOOK_APP_ID=your_facebook_app_id_here
