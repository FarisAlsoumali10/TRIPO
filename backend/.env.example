# ── Server ────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────
MONGODB_URI=mongodb://localhost:27017/tripo

# ── Auth ──────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Google Places API (New) ───────────────
# Get your key at https://console.cloud.google.com/
# Enable "Places API (New)" for your project
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Social OAuth ──────────────────────────
# Google: https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
# Facebook: https://developers.facebook.com/ → Your App → Settings → Basic → App ID
# (Facebook verification is done via Graph API, no secret needed on backend)
