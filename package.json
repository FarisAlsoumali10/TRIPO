{
  "name": "tripo-fullstack",
  "version": "1.0.0",
  "private": true,
  "description": "Tripo - Smart social discovery app for micro-escapes in Saudi Arabia",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "seed": "cd backend && npm run seed",
    "clean": "docker-compose down -v && rm -rf backend/node_modules backend/dist frontend/node_modules frontend/dist node_modules"
  },
  "keywords": [
    "social",
    "discovery",
    "saudi-arabia",
    "travel",
    "itinerary"
  ],
  "author": "Tripo Team",
  "license": "MIT",
  "devDependencies": {
    "@react-native-community/cli": "^20.1.1"
  },
  "dependencies": {
    "mongodb": "^7.1.0"
  }
}
